# Copy this file to .env and fill in your values
# NEVER commit your actual .env to GitHub

# ── Required ──────────────────────────────────────────────────────────────────
# Free Groq API key → https://console.groq.com  (no credit card needed)
GROQ_API_KEY=your_groq_api_key_here

# Discord webhook for your threat intel channel
# Create one: Server Settings → Integrations → Webhooks → New Webhook
DISCORD_WEBHOOK=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# ── Optional ──────────────────────────────────────────────────────────────────
# Slack incoming webhook (if you also want Slack alerts)
# Create one: https://api.slack.com/messaging/webhooks
# SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# Path to the deduplication database (default: seen_articles.db)
# DB_PATH=seen_articles.db
